{
  "name": "adhkar-daily",
  "description": "Adhkar Daily - A sacred space for duʿāʾ, dhikr, and daily remembrance",
  "author": "Ibrahim",
  "private": true,
  "version": "1.0.0",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron": "electron .",
    "rebuild": "electron-builder install-app-deps",
    "electron:dev": "concurrently -k \"npm:dev\" \"npm:electron\"",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win",
    "dist:linux": "npm run build && electron-builder --linux",
    "dist:mac": "npm run build && electron-builder --mac"
  },
  "dependencies": {
    "better-sqlite3": "^12.6.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-icons": "^5.6.0"
  },
  "build": {
    "appId": "com.ibrahim.adhkar-daily",
    "productName": "Adhkar Daily",
    "asar": true,
    "asarUnpack": [
      "**/better-sqlite3/**",
      "**/node_modules/better-sqlite3/**"
    ],
    "extraResources": [
      {
        "from": "electron/islamic-content.db",
        "to": "islamic-content.db"
      }
    ],
    "directories": {
      "buildResources": "build",
      "output": "../Landing-Page/public/downloads"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "!electron/islamic-content.db",
      "build/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico",
      "artifactName": "adhkar-daily.exe",
      "executableName": "Adhkar Daily"
    },
    "nsis": {
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico"
    },
    "linux": {
      "target": "AppImage",
      "icon": "build/icon.png",
      "artifactName": "adhkar-daily-linux.AppImage"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": ["x64", "arm64"]
        },
        {
          "target": "zip",
          "arch": ["x64", "arm64"]
        }
      ],
      "icon": "build/icon.icns",
      "artifactName": "adhkar-daily-${arch}.${ext}",
      "category": "public.app-category.lifestyle",
      "identity": null
    }
  },
  "devDependencies": {
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^9.2.0",
    "cross-env": "^7.0.3",
    "electron": "^37.2.2",
    "electron-builder": "^26.8.1",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.34.3",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-refresh": "^0.4.7",
    "vite": "^5.3.4"
  }
}
